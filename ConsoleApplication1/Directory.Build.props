<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!-- Force MSVC to treat source files as UTF-8 to avoid C4819 when files contain non-ANSI characters -->
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
